import pandas as pd

# Load dataset
def load_data(file_path):
    try:
        df = pd.read_csv(file_path)
        print(" Data loaded successfully")
        return df
    except Exception as e:
        print(f" Error loading file: {e}")
        return None


# Check missing values
def check_missing(df):
    print("\n🔍 Missing Values:")
    missing = df.isnull().sum()
    print(missing[missing > 0])
    return missing


# Check out-of-range values
def check_ranges(df):
    print("\n Out-of-Range Checks:")
    issues = []

    # Example rules (customize based on CRF)
    if 'Age' in df.columns:
        invalid_age = df[(df['Age'] < 0) | (df['Age'] > 120)]
        if not invalid_age.empty:
            issues.append(("Age", invalid_age.index.tolist()))

    if 'HeartRate' in df.columns:
        invalid_hr = df[(df['HeartRate'] < 40) | (df['HeartRate'] > 180)]
        if not invalid_hr.empty:
            issues.append(("HeartRate", invalid_hr.index.tolist()))

    for col, rows in issues:
        print(f"{col} out of range at rows: {rows}")

    return issues


# Check inconsistencies
def check_inconsistencies(df):
    print("\n Logical Inconsistencies:")
    issues = []

    # Example rule: Male cannot be pregnant
    if {'Gender', 'Pregnant'}.issubset(df.columns):
        inconsistent = df[(df['Gender'] == 'Male') & (df['Pregnant'] == 'Yes')]
        if not inconsistent.empty:
            issues.append(("Gender-Pregnancy mismatch", inconsistent.index.tolist()))

    for issue, rows in issues:
        print(f"{issue} at rows: {rows}")

    return issues


# Generate summary report
def generate_report(df):
    print("\n Generating Summary Report...")
    report = {
        "Total Rows": len(df),
        "Total Columns": len(df.columns),
        "Missing Values": df.isnull().sum().to_dict()
    }

    print(report)
    return report


# Main function
def main(file_path):
    df = load_data(file_path)
    if df is not None:
        check_missing(df)
        check_ranges(df)
        check_inconsistencies(df)
        generate_report(df)


if __name__ == "__main__":
    file_path = "mock_clinical_data.csv"  # Replace with your CSV file
    main(file_path)
